{
    "llm": {
        "default_model_key": "ollama_gemma4",
        "models": {
            "ollama_lfm2": {
                "provider": "ollama",
                "model": "lfm2:latest",
                "base_url": "http://localhost:11434"
            },
            "ollama_gemma4": {
                "provider": "ollama",
                "model": "gemma4:26b",
                "base_url": "http://localhost:11434"
            },
            "remote_openai": {
                "provider": "openai",
                "model": "deepseek-ai/DeepSeek-V3",
                "base_url": "https://api.siliconflow.cn/v1",
                "api_key": "sk-jbcbtxhxhezudufxfwedubhxniaqbuoyvsqjkjmecanisqoq"
            }
        },
        "logging": {
            "file_name": "llm_trace.log",
            "max_chars": 10000
        },
        "timeouts": {
            "invoke_seconds": 45
        }
    },
    "paths": {
        "mcp_servers_dir": "mcp_servers",
        "tools_dir": "tools",
        "skill_dir": "skills",
        "logs_dir": "logs",
        "runtime": {
            "snapshot_dir": "runtime_state/snapshots",
            "audit_dir": "runtime_state/audit"
        },
        "memory": {
            "db_file": "memory/memory.db",
            "backup_dir": "memory/backups"
        }
    },
    "timeouts": {
        "tool_invoke_seconds": 20,
        "request_total_seconds": 120,
        "tool_cancellation_grace_seconds": 0.2
    },
    "retention": {
        "auto_prune": {
            "enabled": true,
            "min_interval_seconds": 300
        },
        "logs": {
            "max_age_days": 7,
            "max_files": 20,
            "max_bytes": 0
        },
        "snapshots": {
            "max_age_days": 7,
            "max_request_dirs": 200,
            "max_bytes": 0
        },
        "audit": {
            "max_age_days": 14,
            "max_files": 50,
            "max_bytes": 0
        },
        "memory_backups": {
            "max_age_days": 14,
            "max_files": 20,
            "max_bytes": 0
        }
    },
    "routing": {
        "historical_tool_failures": {
            "reroute_threshold": 2,
            "severity_threshold": 6
        },
        "skill_match": {
            "prompt": {
                "min_overlap": 1,
                "min_ratio": 0.34
            },
            "tool": {
                "min_overlap": 1,
                "min_ratio": 0.34
            }
        }
    },
    "conversation": {
        "intent_rewrite": {
            "enabled": true
        },
        "lite_chat": {
            "enabled": true,
            "persist_memory": false,
            "patterns": [
                "^(你好|您好|嗨|哈喽|hello|hi|hey)[!！。\\s]*$",
                "^(早上好|中午好|下午好|晚上好|晚安)[!！。\\s]*$",
                "^(在吗|有人吗|忙吗)[?？!！。\\s]*$",
                "^(谢谢|感谢|辛苦了|thx|thanks)[!！。\\s]*$"
            ]
        }
    }
}